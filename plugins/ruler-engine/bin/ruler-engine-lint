#!/usr/bin/env bash
# Validate .claude-rules/ruler.yml in cwd (or ancestor).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(dirname "$SCRIPT_DIR")"
# shellcheck source=../lib/ruler-load.sh
source "$PLUGIN_ROOT/lib/ruler-load.sh"

# Parse args
FILE_ARG=""
for arg in "$@"; do
  case "$arg" in
    --file=*) FILE_ARG="${arg#--file=}" ;;
    *) echo "unknown arg: $arg" >&2; exit 2 ;;
  esac
done

MAX_ALWAYS=5
MAX_RULE_FILE_BYTES=500
MAX_ALWAYS_AGG_BYTES=2048

errors=0
err() { echo "ERROR: $*" >&2; echo "ERROR: $*"; errors=$((errors+1)); }
warn() { echo "WARN:  $*" >&2; }

# validate_when_map <rule_idx> <id> <yq_path>
#   Validate a single condition object at the given yq path inside ruler_file.
validate_when_map() {
  local idx="$1" id="$2" path="$3"
  local c_tool c_glob c_regex
  c_tool="$(yq eval "$path.tool // \"\"" "$ruler_file")"
  c_glob="$(yq eval "$path.file_glob // \"\"" "$ruler_file")"
  c_regex="$(yq eval "$path.command_regex // \"\"" "$ruler_file")"
  [[ -z "$c_tool" ]] && err "rule[$idx] ($id) $path: tool required"
  [[ -n "$c_glob" && -n "$c_regex" ]] && err "rule[$idx] ($id) $path: file_glob and command_regex are mutually exclusive"
  if [[ -n "$c_glob" && "$c_tool" == "Bash" ]]; then
    err "rule[$idx] ($id) $path: Bash tool cannot use file_glob (use command_regex)"
  fi
  if [[ -n "$c_regex" && "$c_tool" != "Bash" ]]; then
    err "rule[$idx] ($id) $path: command_regex only valid with Bash"
  fi
}

if [[ -n "$FILE_ARG" ]]; then
  [[ -f "$FILE_ARG" ]] || { echo "ERROR: file not found: $FILE_ARG" >&2; exit 1; }
  ruler_file="$FILE_ARG"
else
  ruler_file="$(find_ruler)" || {
    echo "ERROR: .claude-rules/ruler.yml not found (searched from $PWD upward)" >&2
    exit 1
  }
fi
ruler_dir="$(dirname "$ruler_file")"

# 1) YAML parse
if ! yq eval '.' "$ruler_file" >/dev/null 2>&1; then
  echo "ERROR: ruler.yml has YAML syntax errors" >&2
  echo "ERROR: ruler.yml has YAML syntax errors"
  yq eval '.' "$ruler_file" >/dev/null
  exit 1
fi

# 2) version present
version="$(yq eval '.version // ""' "$ruler_file")"
[[ "$version" != "1" ]] && err "version must be 1, got '$version'"

# 2b) validate optional top-level load_plugin_sources.
# Note: yq emits "!!null" (not "null") for absent fields.
lps_type="$(yq eval '.load_plugin_sources | type' "$ruler_file" 2>/dev/null || echo "!!null")"
if [[ "$lps_type" != "!!null" && "$lps_type" != "!!bool" ]]; then
  err "load_plugin_sources must be boolean, got $lps_type"
fi

# 2c) validate optional top-level disable
disable_type="$(yq eval '.disable | type' "$ruler_file" 2>/dev/null || echo "!!null")"
if [[ "$disable_type" != "!!null" && "$disable_type" != "!!seq" ]]; then
  err "disable must be an array of strings, got $disable_type"
else
  if [[ "$disable_type" == "!!seq" ]]; then
    n_dis="$(yq eval '.disable | length' "$ruler_file")"
    for ((k=0; k<n_dis; k++)); do
      dt="$(yq eval ".disable[$k] | type" "$ruler_file")"
      [[ "$dt" != "!!str" ]] && err "disable[$k] must be string"
    done
  fi
fi

# 3) each rule check
n_rules="$(yq eval '.rules | length' "$ruler_file")"
[[ "$n_rules" == "null" || "$n_rules" == "0" ]] && err "rules[] is empty"

always_count=0
for ((i=0; i<n_rules; i++)); do
  id="$(yq eval ".rules[$i].id // \"\"" "$ruler_file")"
  inject="$(yq eval ".rules[$i].inject // \"\"" "$ruler_file")"
  when_type="$(yq eval ".rules[$i].when | type" "$ruler_file")"
  when_value="$(yq eval ".rules[$i].when" "$ruler_file")"

  [[ -z "$id" ]] && err "rule[$i]: id is required"
  [[ -z "$inject" ]] && err "rule[$i] ($id): inject is required"

  if [[ -n "$inject" ]] && [[ ! -f "$ruler_dir/$inject" ]]; then
    err "rule[$i] ($id): inject file not found: $inject"
  fi

  # inject file size check
  if [[ -f "$ruler_dir/$inject" ]]; then
    size="$(wc -c < "$ruler_dir/$inject")"
    (( size > MAX_RULE_FILE_BYTES )) && warn "rule[$i] ($id): rule file >$MAX_RULE_FILE_BYTES bytes ($size)"
  fi

  # when validation
  case "$when_type" in
    "!!str")
      [[ "$when_value" != "always" ]] && err "rule[$i] ($id): when string must be 'always', got '$when_value'"
      [[ "$when_value" == "always" ]] && always_count=$((always_count+1))
      ;;
    "!!map")
      validate_when_map "$i" "$id" ".rules[$i].when"
      ;;
    "!!seq")
      # array - each element must be object; 'always' literal not allowed in array
      n_conds="$(yq eval ".rules[$i].when | length" "$ruler_file")"
      for ((j=0; j<n_conds; j++)); do
        ct="$(yq eval ".rules[$i].when[$j] | type" "$ruler_file")"
        if [[ "$ct" != "!!map" ]]; then
          err "rule[$i] ($id): when[$j] must be an object (cannot mix 'always' with conditions)"
          continue
        fi
        validate_when_map "$i" "$id" ".rules[$i].when[$j]"
      done
      ;;
    *)
      err "rule[$i] ($id): when has invalid type $when_type"
      ;;
  esac
done

(( always_count > MAX_ALWAYS )) && err "too many 'when: always' rules ($always_count > $MAX_ALWAYS)"

if (( errors > 0 )); then
  echo "ruler-engine-lint: $errors error(s)" >&2
  echo "ruler-engine-lint: $errors error(s)"
  exit 1
fi

# Aggregate always-rules size warning
agg=0
for ((i=0; i<n_rules; i++)); do
  w="$(yq eval ".rules[$i].when" "$ruler_file")"
  if [[ "$w" == "always" ]]; then
    inj="$(yq eval ".rules[$i].inject" "$ruler_file")"
    [[ -f "$ruler_dir/$inj" ]] && agg=$((agg + $(wc -c < "$ruler_dir/$inj")))
  fi
done
(( agg > MAX_ALWAYS_AGG_BYTES )) && warn "aggregate always-rules size ${agg}B exceeds ${MAX_ALWAYS_AGG_BYTES}B — every prompt will carry this overhead"

# Dangling disable check: any disable pattern that matches no known rule id
if [[ "$disable_type" == "!!seq" && -z "$FILE_ARG" ]]; then
  # Build set of all known ids (project + plugin sources if opt-in)
  known_ids=()
  lps_val="$(yq eval '.load_plugin_sources // false' "$ruler_file")"
  # project ids (unprefixed)
  for ((i=0; i<n_rules; i++)); do
    known_ids+=("$(yq eval ".rules[$i].id" "$ruler_file")")
  done
  # plugin ids (namespaced)
  if [[ "$lps_val" == "true" ]]; then
    while IFS=$'\t' read -r ns ruler; do
      [[ -z "$ns" ]] && continue
      nn="$(yq eval '.rules | length' "$ruler" 2>/dev/null || echo 0)"
      for ((j=0; j<nn; j++)); do
        known_ids+=("$ns/$(yq eval ".rules[$j].id" "$ruler")")
      done
    done < <(find_plugin_sources 2>/dev/null)
  fi

  n_dis="$(yq eval '.disable | length' "$ruler_file")"
  for ((k=0; k<n_dis; k++)); do
    pat="$(yq eval ".disable[$k]" "$ruler_file")"
    matched=0
    for kid in "${known_ids[@]}"; do
      case "$kid" in
        $pat) matched=1; break ;;
      esac
    done
    (( matched == 0 )) && warn "disable[$k]: no rule matches '$pat' (dangling — plugin uninstalled?)"
  done
fi

echo "ruler-engine-lint: OK ($n_rules rules, $always_count always)"
