#!/usr/bin/env bash
set -euo pipefail

if [ "${1:-}" = "models" ]; then
  [ "${TABOC_MOCK_MODELS_EMPTY:-}" = 1 ] && exit 75
  if [ -n "${TABOC_MOCK_DB_LOCK_DIR:-}" ]; then
    mkdir "${TABOC_MOCK_DB_LOCK_DIR}" 2>/dev/null || { echo 'database is locked' >&2; exit 75; }
    trap 'rmdir "${TABOC_MOCK_DB_LOCK_DIR}" 2>/dev/null || true' EXIT
    sleep 0.1
  fi
  if [ "${3:-}" = "--verbose" ] || [ "${2:-}" = "--verbose" ]; then
    cat <<'EOF'
opencode/deepseek-v4-flash-free
{
  "variants": {
    "low": {},
    "medium": {},
    "high": {},
    "max": {}
  }
}
opencode/nemotron-3-ultra-free
{
  "variants": {
    "low": {},
    "medium": {},
    "high": {}
  }
}
EOF
  else
    printf '%s\n' 'opencode/deepseek-v4-flash-free' 'opencode/nemotron-3-ultra-free'
  fi
  exit 0
fi

if [ "${1:-}" = "run" ]; then
  MODEL=""
  VARIANT=""
  REPO=""
  TITLE=""
  shift
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --model) MODEL="$2"; shift 2 ;;
      --variant) VARIANT="$2"; shift 2 ;;
      --dir) REPO="$2"; shift 2 ;;
      --title) TITLE="$2"; shift 2 ;;
      --format) shift 2 ;;
      *) shift ;;
    esac
  done
  if [ -n "${TABOC_MOCK_RUN_DB_LOCK_DIR:-}" ]; then
    mkdir "${TABOC_MOCK_RUN_DB_LOCK_DIR}" 2>/dev/null || { echo 'database is locked' >&2; exit 75; }
    trap 'rmdir "${TABOC_MOCK_RUN_DB_LOCK_DIR}" 2>/dev/null || true' EXIT
    sleep 0.15
  fi
  printf '%s|%s|%s|%s|%s|%s|%s\n' "${MODEL}" "${VARIANT:-default}" "${OPENCODE_PERMISSION:-}" \
    "${TABOC_MODELS:-}" "${TABOC_MAX_ATTEMPTS:-}" "${TABOC_ATTEMPT_TIMEOUT:-}" \
    "${TABOC_ATTEMPT_HARD_TIMEOUT:-}" >> "${REPO}/.taboc/mock-calls.log"
  [ -f "${REPO}/.taboc/mock-sleep" ] && sleep 1
  if [ "${MODEL}" = "opencode/deepseek-v4-flash-free" ] && [ -f "${REPO}/.taboc/mock-active-long" ]; then
    for STEP in 1 2 3 4 5; do
      printf '{"type":"text","text":"progress-%s"}\n' "${STEP}"
      sleep 0.4
    done
  fi
  if [ "${MODEL}" = "opencode/deepseek-v4-flash-free" ] && [ -f "${REPO}/.taboc/mock-deepseek-hang" ]; then
    sleep 5
  fi
  if [ "${MODEL}" = "opencode/deepseek-v4-flash-free" ] && [ -f "${REPO}/.taboc/mock-deepseek-fail" ]; then
    echo '{"type":"error","error":"429 quota exceeded"}'
    exit 1
  fi
  WORKER_ID="${TITLE#taboc-}"
  if [ -f "${REPO}/.taboc/mock-output-only" ]; then
    printf '{"type":"text","part":{"text":"[HANDOFF] %s → root | recovered from final output"}}\n' "${WORKER_ID}"
    exit 0
  fi
  if [ ! -f "${REPO}/.taboc/mock-no-terminal" ]; then
    printf '[HANDOFF] %s → root | mock complete\n' "${WORKER_ID}" >> "${REPO}/.taboc/journal.md"
  fi
  echo '{"type":"text","text":"done"}'
  exit 0
fi

exit 2
